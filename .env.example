# =============================================================================
# RAG Arena 2026 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# --- LLM Provider API Keys ---
# OpenRouter is the only remote LLM provider used by the app.
OPENROUTER_API_KEY=
ADMIN_SETTINGS_TOKEN=
ENVIRONMENT=development

# --- Model Configuration ---
# Bootstrap-only seed list. Runtime settings in SQLite become authoritative after boot.
#
# Examples:
#   openrouter/google/gemini-2.5-flash
#   openrouter/anthropic/claude-3.7-sonnet
AVAILABLE_MODELS=openrouter/google/gemini-2.5-flash,openrouter/anthropic/claude-3.7-sonnet

# Default model (first in AVAILABLE_MODELS if not set)
DEFAULT_MODEL=openrouter/google/gemini-2.5-flash

# --- Embedding & Reranking Models ---
# OpenRouter embedding fallback when runtime settings have no embeddings model.
EMBEDDING_MODEL=openrouter/openai/text-embedding-3-small
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- LangExtract (Tier 3+ metadata enrichment) ---
# Model that generates title/summary/keywords per chunk during ingestion.
# Same provider/model format as AVAILABLE_MODELS above.
LANGEXTRACT_MODEL=openrouter/google/gemini-2.5-flash

# --- Semantic Cache (Tier 4) ---
# TTL in seconds for cached answers. Set to 0 to disable.
SEMANTIC_CACHE_TTL=3600
SEMANTIC_CACHE_THRESHOLD=0.92

# --- Optional ---
# Cal.com booking link (injected into CTA buttons)
CALCOM_LINK=https://cal.com/your-username
