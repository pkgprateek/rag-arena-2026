# =============================================================================
# RAG Arena 2026 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# --- LLM Provider API Keys ---
# At least one provider is required.

# Groq (fast inference)
GROQ_API_KEY=

# OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=

# Google AI Studio (Gemini)
GOOGLE_AI_STUDIO_API_KEY=

# --- Model Configuration ---
# Comma-separated list of models. Format: provider/model-name
#
# The FIRST segment is which API key to use (groq / openrouter / google).
# The REST is the actual model name sent to that provider.
#
# Examples:
#   groq/groq/compound                         → Groq API, model "groq/compound"
#   groq/llama-3.3-70b-versatile               → Groq API, model "llama-3.3-70b-versatile"
#   openrouter/google/gemini-flash-1.5         → OpenRouter API, model "google/gemini-flash-1.5"
#   google/gemini-2.0-flash                    → Google AI Studio, model "gemini-2.0-flash"
AVAILABLE_MODELS=groq/groq/compound,groq/llama-3.3-70b-versatile

# Default model (first in AVAILABLE_MODELS if not set)
DEFAULT_MODEL=groq/groq/compound

# --- Embedding & Reranking Models ---
# Local HuggingFace models downloaded on first run and cached in Docker volume.
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Unstructured (Tier 2+ document parsing + OCR) ---
# Get a free key at https://platform.unstructuredapp.io (10k pages free)
# Without this, Tier 2+ falls back to basic text extraction (no OCR, no tables).
UNSTRUCTURED_API_KEY=

# --- LangExtract (Tier 3+ metadata enrichment) ---
# Model that generates title/summary/keywords per chunk during ingestion.
# Same provider/model format as AVAILABLE_MODELS above.
LANGEXTRACT_MODEL=groq/groq/compound

# --- Semantic Cache (Tier 4) ---
# TTL in seconds for cached answers. Set to 0 to disable.
SEMANTIC_CACHE_TTL=3600
SEMANTIC_CACHE_THRESHOLD=0.92

# --- Optional ---
# Cal.com booking link (injected into CTA buttons)
CALCOM_LINK=https://cal.com/your-username
