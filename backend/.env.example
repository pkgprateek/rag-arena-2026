# ==============================================================================
# RAG Arena 2026 — Backend Environment Variables
# Copy this file to .env and fill in the values.
# On Railway/Vercel, set these as environment variables directly — do NOT commit .env
# ==============================================================================

# --- LLM Providers ---
# Add at least one of these. The first valid key wins for routing.
GROQ_API_KEY=""
OPENROUTER_API_KEY=""
GOOGLE_AI_STUDIO_API_KEY=""

# --- Models ---
# Comma-separated list. Format: provider/model-name
# Examples:
#   groq/llama-3.3-70b-versatile
#   openrouter/anthropic/claude-3.5-sonnet
#   google/gemini-2.0-flash
AVAILABLE_MODELS="groq/llama-3.3-70b-versatile,groq/llama-3.1-8b-instant"
DEFAULT_MODEL="groq/llama-3.3-70b-versatile"

# --- Redis ---
# Local dev: redis://localhost:6379/0
# Docker Compose: redis://redis:6379  (set automatically by docker-compose.yml)
REDIS_URL="redis://localhost:6379/0"

# --- ChromaDB ---
# Local dev: http://localhost:8000
# Docker Compose: http://chroma:8000  (set automatically by docker-compose.yml)
CHROMA_URL="http://localhost:8000"

# --- Unstructured Serverless API ---
# Sign up at https://platform.unstructuredapp.io to get a free API key.
# Without this, Tiers 2+ will gracefully fall back to basic pypdf parsing.
UNSTRUCTURED_API_KEY=""

# --- Server ---
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000
FRONTEND_URL="http://localhost:5173"

# --- Optional ---
CALCOM_LINK="https://cal.com/your-username"
