# ==============================================================================
# RAG Arena 2026 — Backend Environment Variables
# Copy this file to .env and fill in the values.
# On Railway/Vercel, set these as environment variables directly — do NOT commit .env
# ==============================================================================

# --- LLM Provider ---
OPENROUTER_API_KEY=""
ADMIN_SETTINGS_TOKEN=""
ENVIRONMENT="development"

# --- Redis ---
# Local dev: redis://localhost:6379/0
# Docker Compose: redis://redis:6379  (set automatically by docker-compose.yml)
REDIS_URL="redis://localhost:6379/0"

# --- ChromaDB ---
# Local dev: http://localhost:8000
# Docker Compose: http://chroma:8000  (set automatically by docker-compose.yml)
CHROMA_URL="http://localhost:8000"

# --- Server ---
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000
FRONTEND_URL="http://localhost:5173"

# --- Local llama.cpp reranker ---
RERANKER_ENABLED=true
RERANKER_BASE_URL="http://127.0.0.1:8081"
RERANKER_TIMEOUT_SECONDS=5.0
RERANKER_HEALTH_PATH="/health"
RERANKER_API_PATH="/v1/rerank"
RERANKER_MODEL_CACHE_DIR="/app/cache/reranker"
RERANKER_MODEL_FILENAME="qwen3-reranker-0.6b-q8_0.gguf"
RERANKER_SERVER_HOST="127.0.0.1"
RERANKER_SERVER_PORT=8081
