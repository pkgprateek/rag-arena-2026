# ==============================================================================
# RAG Arena 2026 — Backend Environment Variables
# Copy this file to .env and fill in the values.
# On Railway/Vercel, set these as environment variables directly — do NOT commit .env
# ==============================================================================

# --- LLM Provider ---
OPENROUTER_API_KEY=""
ADMIN_SETTINGS_TOKEN=""
ENVIRONMENT="development"

# --- Models ---
# Bootstrap-only seed list. Runtime DB state becomes authoritative after init.
# Examples:
#   openrouter/google/gemini-2.5-flash
#   openrouter/anthropic/claude-3.7-sonnet
AVAILABLE_MODELS="openrouter/google/gemini-2.5-flash,openrouter/anthropic/claude-3.7-sonnet"
DEFAULT_MODEL="openrouter/google/gemini-2.5-flash"

# OpenRouter fallback models used for non-chat tasks when runtime settings do not define one.
EMBEDDING_MODEL="openrouter/openai/text-embedding-3-small"
LANGEXTRACT_MODEL="openrouter/google/gemini-2.5-flash"

# --- Redis ---
# Local dev: redis://localhost:6379/0
# Docker Compose: redis://redis:6379  (set automatically by docker-compose.yml)
REDIS_URL="redis://localhost:6379/0"

# --- ChromaDB ---
# Local dev: http://localhost:8000
# Docker Compose: http://chroma:8000  (set automatically by docker-compose.yml)
CHROMA_URL="http://localhost:8000"

# --- Server ---
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000
FRONTEND_URL="http://localhost:5173"

# --- Optional ---
CALCOM_LINK="https://cal.com/your-username"
